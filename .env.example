# Aviation ERP Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (found in Project Settings -> API)
SUPABASE_KEY=your-anon-key

# Your Supabase service role key (for admin operations - keep secret!)
SUPABASE_SERVICE_KEY=your-service-role-key

# =============================================================================
# AFRICA'S TALKING SMS CONFIGURATION
# =============================================================================
# Get your API key from Africa's Talking dashboard
# Sandbox mode: https://account.africastalking.com/apps/sandbox
# Production: https://account.africastalking.com/apps/production
AFRICAS_TALKING_API_KEY=your-africas-talking-api-key

# Your Africa's Talking username (usually 'sandbox' for testing)
AFRICAS_TALKING_USERNAME=sandbox

# Your sender ID or short code (optional - leave empty if using sandbox)
AFRICAS_TALKING_SENDER_ID=YOUR_SENDER_ID

# Phone number to receive order notifications (international format)
# Example: +254712345678
SMS_RECIPIENT=+254712345678

# =============================================================================
# DATABASE (Optional - for direct PostgreSQL connections)
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# APP CONFIGURATION
# =============================================================================
# Set to 'true' for debug mode
DEBUG=false

# =============================================================================
# CORS CONFIGURATION (Frontend Domains)
# =============================================================================
# Admin frontend domain (e.g., https://admin-yourapp.onrender.com)
ADMIN_DOMAIN=

# Staff/Sales frontend domain
STAFF_DOMAIN=

# Alternative sales domain
SALES_DOMAIN=

