# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Render Deployment Domain (Required for CORS)
ADMIN_DOMAIN=https://your-app.onrender.com
STAFF_DOMAIN=https://staff.example.com
SALES_DOMAIN=https://sales.example.com

# Africa's Talking SMS Configuration (Optional)
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=your-sender-id
SMS_RECIPIENT=+254700000000

# Twilio SMS Configuration (Optional)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Default Delivery Location (Optional)
DEFAULT_DELIVERY_LOCATION=Warehouse

# Debug Mode (Optional)
DEBUG=False

